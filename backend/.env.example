# Server
NODE_ENV=development
PORT=4000
API_BASE_URL=http://localhost:4000

# Database setup (after MySQL is running and .env is configured):
#   npm run db:migrate   # create tables (versioned migrations)
#   npm run db:sync      # alternative: sync tables from models (alter if DB_SYNC_ALTER=true)
#   npm run seed         # optional: seed demo data

# MySQL (phpMyAdmin / local)
DB_HOST=127.0.0.1
# DB_PORT=3306
DB_NAME=creator_platform
DB_USER=root
DB_PASSWORD=your_password

# JWT
JWT_SECRET=change_me_to_long_random_string_min_32_chars
JWT_EXPIRES_IN=7d

# Platform (basis points: 1000 = 10%)
PLATFORM_FEE_BPS=1000

# Payment freeze: transfer to creator after N hours (0 = immediate after capture policy)
CREATOR_PAYOUT_DELAY_HOURS=48

# Session cancellation: full refund if cancelled >= this many hours before slot start
SESSION_FULL_REFUND_HOURS=24

# When creator cancels: fee (basis points of refund) deducted from creator's next payout (e.g. 1000 = 10%)
CREATOR_CANCELLATION_FEE_BPS=1000

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_DEFAULT_CURRENCY=usd

# Razorpay (Payment test & checkout — get test keys from https://dashboard.razorpay.com → Settings → API Keys)
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=

# Default payment provider for create-order: stripe | razorpay
DEFAULT_PAYMENT_PROVIDER=stripe
